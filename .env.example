# ============================================================
# TOAS — Teacher Online Attendance System
# Copy this file to .env.local and fill in the values.
# ============================================================

# ── Database (PostgreSQL direct) ─────────────────────────────
# Supabase: Dashboard → Project Settings → Database → Connection string (URI)
# Use Transaction mode (port 6543) — suitable for serverless / Next.js
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── LINE OAuth ───────────────────────────────────────────────
# Create a LINE Login channel at: https://developers.line.biz/
LINE_CLIENT_ID=your-line-channel-id
LINE_CLIENT_SECRET=your-line-channel-secret

# ── NextAuth ─────────────────────────────────────────────────
# NEXTAUTH_URL must be your production domain (exact URL, no trailing slash)
NEXTAUTH_URL=https://your-domain.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-string

# ── School geofence ──────────────────────────────────────────
# Coordinates of the school (centre of the geofence)
NEXT_PUBLIC_SCHOOL_LAT=13.736717
NEXT_PUBLIC_SCHOOL_LNG=100.523186
# Radius in metres — teachers within this range are classified as 'campus'
NEXT_PUBLIC_GEOFENCE_RADIUS=500

# ── Attendance rules ─────────────────────────────────────────
# IANA timezone name — all date/time logic runs in this timezone
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
NEXT_PUBLIC_SCHOOL_TZ=Asia/Bangkok
# Check-in after this time (HH:mm, 24-hour, school timezone) is marked 'late'
NEXT_PUBLIC_CHECKIN_CUTOFF=08:00
# Checkout button is enabled only after this time (school timezone)
NEXT_PUBLIC_CHECKOUT_AVAILABLE_AFTER=16:30
